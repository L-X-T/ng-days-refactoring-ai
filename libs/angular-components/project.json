{
  "name": "angular-components",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "libs/angular-components",
  "prefix": "lxt",
  "targets": {
    "build": {
      "executor": "@nx/angular:package",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/angular-components/ng-package.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/angular-components/tsconfig.lib.prod.json"
        },
        "development": {
          "tsConfig": "libs/angular-components/tsconfig.lib.json"
        }
      },
      "defaultConfiguration": "production"
    },
    "build-npm": {
      "dependsOn": [
        {
          "target": "build"
        }
      ],
      "command": "rm -rf dist/libs/angular-components/src"
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    }
  },
  "tags": ["type:ui", "domain:shared"],
  "generators": {
    "@nx/angular:component": {
      "style": "scss",
      "changeDetection": "OnPush",
      "viewEncapsulation": "None"
    },
    "@schematics/angular:component": {
      "style": "scss",
      "changeDetection": "OnPush",
      "viewEncapsulation": "None"
    }
  }
}
